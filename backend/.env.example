# Copy to .env for local (non-docker) development. Every value has a working default;
# only RESEND_API_KEY is needed to send real email (otherwise emails print to stdout).

DATABASE_URL=postgresql+psycopg://alma:alma@localhost:5432/alma
JWT_SECRET=dev-secret-change-me-32-bytes-minimum!

# Internal dashboard login — dev fallback credentials (work without any OAuth setup)
ADMIN_EMAIL=attorney@example.com
ADMIN_PASSWORD=letmein

# Google Sign-In (primary admin login). Create an OAuth "Web application" client ID in
# Google Cloud Console with http://localhost:3000 as an authorized JavaScript origin,
# then set it here AND as NEXT_PUBLIC_GOOGLE_CLIENT_ID for the frontend build.
# Empty = Google button hidden, fallback credentials only.
GOOGLE_CLIENT_ID=
# Comma-separated Google accounts allowed into the admin dashboard.
ADMIN_ALLOWED_EMAILS=nhshpr@gmail.com,noahs921@gmail.com,noahshapiro.dev@gmail.com

# Email (Resend). Leave RESEND_API_KEY empty to log emails to stdout instead.
RESEND_API_KEY=
EMAIL_FROM=Alma <onboarding@resend.dev>
ATTORNEY_NOTIFICATION_EMAIL=attorney@example.com

FRONTEND_ORIGIN=http://localhost:3000

# Resume storage: S3-compatible object storage (MinIO locally, AWS S3 in prod).
# Leave S3_ENDPOINT_URL empty to fall back to local disk at UPLOAD_DIR.
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=resumes
S3_ACCESS_KEY=alma
S3_SECRET_KEY=alma-minio-secret
S3_REGION=us-east-1
UPLOAD_DIR=var/uploads
